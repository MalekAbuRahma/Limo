# Local test environment — NOT for production.
# Usage:
#   npm run server:test   (API with auth bypass)
#   npm run dev:test      (Vite loads this file via --mode test)
# Or copy these lines into .env.local alongside your DATABASE_URL.

AUTH_DISABLED=1
VITE_FAKE_LOGIN=true

# Fixed test credentials (API accepts any password when AUTH_DISABLED=1)
ENSURE_ADMIN=admin:test1234
ADMIN_USERNAME=admin
ADMIN_INITIAL_PASSWORD=test1234
ADMIN_DISPLAY_NAME=مدير تجريبي

API_PORT=3001
VITE_DEV_PORT=3000

# Override in .env.local if your Postgres password differs:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vip_limousine_cars
