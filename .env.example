# PostgreSQL connection (required for the API server)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vip_limousine_cars

# API port (optional; dev default 3001)
API_PORT=3001

# Auth — first-run admin (created only when users table is empty)
ADMIN_USERNAME=admin
ADMIN_INITIAL_PASSWORD=admin
ADMIN_DISPLAY_NAME=مدير النظام

# Create/update admin on API start (then log in as that user)
# ENSURE_ADMIN=admin:1234
# ENSURE_USERS=saleh:1234:Saleh:user

# Set AUTH_DISABLED=1 to skip login on API (local dev only)
# AUTH_DISABLED=1

# Frontend API base (empty = same origin; set only if API is on another host)
# VITE_API_URL=

# Production deploy: see .env.production.example and docker-compose.prod.yml
