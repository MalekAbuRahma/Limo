# PostgreSQL connection (required for the API server)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vip_limousine_cars

# API port (optional; dev default 3001)
API_PORT=3001

# Frontend API base (empty = same origin; set only if API is on another host)
# VITE_API_URL=

