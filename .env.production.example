# Copy to .env on the server: cp .env.production.example .env

# PostgreSQL (used by docker-compose.prod.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=vip_limousine_cars

# Public HTTP port (80 is often used by Apache/cPanel — use 8080 if busy)
APP_PORT=8080

# Optional: Google Gemini (AI features in the dashboard)
GEMINI_API_KEY=
